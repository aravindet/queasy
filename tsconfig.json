{
    "compilerOptions": {
        "strict": true,
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rewriteRelativeImportExtensions": true,
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "erasableSyntaxOnly": true,
        "resolveJsonModule": true,
        "lib": ["ES2022"]
    },
    "include": ["src/**/*.ts"]
}
